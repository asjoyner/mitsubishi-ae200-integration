{
  "dashboard": {
    "title": "AE-200 Geothermal HVAC",
    "uid": "ae200-hvac",
    "timezone": "browser",
    "refresh": "30s",
    "time": {"from": "now-6h", "to": "now"},
    "templating": {
      "list": [
        {
          "name": "unit",
          "type": "query",
          "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
          "query": "SHOW TAG VALUES FROM ae200_temperature WITH KEY = \"group_name\"",
          "includeAll": true,
          "multi": true,
          "current": {"selected": true, "text": "All", "value": "$__all"}
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Room Temperatures",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 0},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "fahrenheit",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") * 9 / 5 + 32 FROM \"ae200_temperature\" WHERE \"type\" = 'inlet' AND \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      },
      {
        "id": 2,
        "title": "Setpoint Temperatures",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 0},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "fahrenheit",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0,
              "lineStyle": {"fill": "dash", "dash": [10, 10]},
              "spanNulls": true
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") * 9 / 5 + 32 FROM \"ae200_temperature\" WHERE \"type\" = 'setpoint' AND \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      },
      {
        "id": 3,
        "title": "Room vs Setpoint (per unit)",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 10},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "fahrenheit",
            "custom": {"lineWidth": 2, "spanNulls": true}
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": ".*setpoint.*|.*setpoint_cool.*|.*setpoint_heat.*"},
              "properties": [
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            },
            {
              "matcher": {"id": "byRegexp", "options": ".*inlet.*"},
              "properties": [
                {"id": "custom.fillOpacity", "value": 15}
              ]
            }
          ]
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") * 9 / 5 + 32 FROM \"ae200_temperature\" WHERE (\"type\" = 'inlet' OR \"type\" = 'setpoint' OR \"type\" = 'setpoint_cool' OR \"type\" = 'setpoint_heat') AND \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\", \"type\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name ($tag_type)"
          }
        ]
      },
      {
        "id": 4,
        "title": "Hot Water System",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 10},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "fahrenheit",
            "custom": {"lineWidth": 2, "fillOpacity": 10, "spanNulls": true}
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") * 9 / 5 + 32 FROM \"ae200_temperature\" WHERE \"group_name\" = 'HOT WATER SYSTEM' AND (\"type\" = 'inlet' OR \"type\" = 'setpoint') AND $timeFilter GROUP BY time($__interval), \"type\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_type"
          }
        ]
      },
      {
        "id": 5,
        "title": "Drive State (ON/OFF)",
        "type": "state-timeline",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "OFF", "color": "dark-blue"}, "1": {"text": "ON", "color": "dark-green"}}}
            ],
            "custom": {"fillOpacity": 80}
          }
        },
        "options": {
          "showValue": "auto",
          "mergeValues": true,
          "legend": {"displayMode": "list", "placement": "bottom"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"drive\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      },
      {
        "id": 6,
        "title": "HVAC Mode",
        "type": "state-timeline",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {
                "HEAT": {"text": "Heat", "color": "dark-orange"},
                "HEATING": {"text": "Heating", "color": "dark-orange"},
                "COOL": {"text": "Cool", "color": "dark-blue"},
                "COOLING": {"text": "Cooling", "color": "dark-blue"},
                "AUTO": {"text": "Auto", "color": "dark-green"},
                "AUTOHEAT": {"text": "Auto (Heat)", "color": "orange"},
                "AUTOCOOL": {"text": "Auto (Cool)", "color": "blue"},
                "DRY": {"text": "Dry", "color": "dark-yellow"},
                "FAN": {"text": "Fan", "color": "dark-purple"}
              }},
              {"type": "special", "options": {"match": "empty", "result": {"text": "Unknown", "color": "text"}}}
            ],
            "custom": {"fillOpacity": 80}
          }
        },
        "options": {
          "showValue": "auto",
          "mergeValues": true,
          "legend": {"displayMode": "list", "placement": "bottom"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"mode\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      },
      {
        "id": 7,
        "title": "Current Status",
        "type": "table",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 36},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {},
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Time"},
              "properties": [{"id": "custom.hidden", "value": true}]
            },
            {
              "matcher": {"id": "byName", "options": "Power"},
              "properties": [
                {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "OFF"}, "1": {"text": "ON"}}}]},
                {"id": "custom.cellOptions", "value": {"type": "color-text"}},
                {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "dark-blue"}, {"value": 1, "color": "dark-green"}]}}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "error_sign"},
              "properties": [
                {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "OK"}, "1": {"text": "ERROR"}}}]},
                {"id": "custom.cellOptions", "value": {"type": "color-text"}},
                {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "dark-green"}, {"value": 1, "color": "dark-red"}]}}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "filter_sign"},
              "properties": [
                {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "OK"}, "1": {"text": "SERVICE"}}}]},
                {"id": "custom.cellOptions", "value": {"type": "color-text"}},
                {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"value": null, "color": "dark-green"}, {"value": 1, "color": "dark-yellow"}]}}
              ]
            }
          ]
        },
        "options": {
          "showHeader": true,
          "sortBy": [{"displayName": "group_name", "desc": false}]
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"drive\") AS \"Power\", last(\"mode\") AS \"mode\", last(\"fan_speed\") AS \"fan_speed\", last(\"error_sign\") AS \"error_sign\", last(\"filter_sign\") AS \"filter_sign\" FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND $timeFilter GROUP BY \"group_name\"",
            "rawQuery": true,
            "resultFormat": "table"
          }
        ]
      },
      {
        "id": 8,
        "title": "Error & Filter Alerts",
        "type": "stat",
        "gridPos": {"h": 5, "w": 12, "x": 0, "y": 44},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "OK", "color": "dark-green"}, "1": {"text": "ALERT", "color": "dark-red"}}}
            ],
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "red"}]}
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["last"]},
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"error_sign\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND $timeFilter GROUP BY \"group_name\"",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name error"
          }
        ]
      },
      {
        "id": 9,
        "title": "Filter Status",
        "type": "stat",
        "gridPos": {"h": 5, "w": 12, "x": 12, "y": 44},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "OK", "color": "dark-green"}, "1": {"text": "SERVICE", "color": "dark-yellow"}}}
            ],
            "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 1, "color": "yellow"}]}
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["last"]},
          "colorMode": "background",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"filter_sign\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND $timeFilter GROUP BY \"group_name\"",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name filter"
          }
        ]
      },
      {
        "id": 10,
        "title": "Fan Speed",
        "type": "state-timeline",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {
                "AUTO": {"text": "Auto", "color": "dark-green"},
                "LOW": {"text": "Low", "color": "light-blue"},
                "MID2": {"text": "Med-Low", "color": "blue"},
                "MID1": {"text": "Med-High", "color": "dark-blue"},
                "HIGH": {"text": "High", "color": "dark-purple"}
              }}
            ],
            "custom": {"fillOpacity": 80}
          }
        },
        "options": {
          "showValue": "auto",
          "mergeValues": true,
          "legend": {"displayMode": "list", "placement": "bottom"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"fan_speed\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
