{
  "dashboard": {
    "title": "Climate Control",
    "uid": "climate-control",
    "timezone": "browser",
    "refresh": "30s",
    "time": {"from": "now-6h", "to": "now"},
    "templating": {
      "list": [
        {
          "name": "unit",
          "type": "query",
          "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
          "query": "SHOW TAG VALUES FROM ae200_temperature WITH KEY = \"group_name\" WHERE \"group_name\" != 'HOT WATER SYSTEM'",
          "includeAll": true,
          "multi": true,
          "current": {"selected": true, "text": "All", "value": "$__all"}
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Temperature vs Target",
        "description": "Room temperatures with target +-1F band overlay",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "fahrenheit",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Target"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}},
                {"id": "custom.lineWidth", "value": 3},
                {"id": "custom.lineStyle", "value": {"fill": "solid"}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Target +1F"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}},
                {"id": "custom.lineWidth", "value": 1},
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Target -1F"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}},
                {"id": "custom.lineWidth", "value": 1},
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            }
          ]
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") * 9 / 5 + 32 FROM \"ae200_temperature\" WHERE \"type\" = 'inlet' AND \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          },
          {
            "refId": "B",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"value\") FROM \"homeassistant\".\"autogen\".\"°F\" WHERE \"entity_id\" = 'hvac_target_temp' AND $timeFilter GROUP BY time($__interval) fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "Target"
          },
          {
            "refId": "C",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"value\") + 1 FROM \"homeassistant\".\"autogen\".\"°F\" WHERE \"entity_id\" = 'hvac_target_temp' AND $timeFilter GROUP BY time($__interval) fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "Target +1F"
          },
          {
            "refId": "D",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"value\") - 1 FROM \"homeassistant\".\"autogen\".\"°F\" WHERE \"entity_id\" = 'hvac_target_temp' AND $timeFilter GROUP BY time($__interval) fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "Target -1F"
          }
        ]
      },
      {
        "id": 2,
        "title": "Fan Speed Over Time",
        "type": "state-timeline",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 10},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {
                "AUTO": {"text": "Auto", "color": "dark-green"},
                "LOW": {"text": "Low", "color": "light-blue"},
                "MID2": {"text": "Med-Low", "color": "blue"},
                "MID1": {"text": "Med-High", "color": "dark-blue"},
                "HIGH": {"text": "High", "color": "dark-purple"}
              }}
            ],
            "custom": {"fillOpacity": 80}
          }
        },
        "options": {
          "showValue": "auto",
          "mergeValues": true,
          "legend": {"displayMode": "list", "placement": "bottom"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"fan_speed\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      },
      {
        "id": 3,
        "title": "CO2 Levels",
        "description": "Per-zone CO2 with 600/800 ppm threshold lines",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 18},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "ppm",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": null, "color": "green"},
                {"value": 600, "color": "yellow"},
                {"value": 800, "color": "red"}
              ]
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "600 ppm"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}},
                {"id": "custom.lineWidth", "value": 1},
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "800 ppm"},
              "properties": [
                {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
                {"id": "custom.lineWidth", "value": 1},
                {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
                {"id": "custom.fillOpacity", "value": 0}
              ]
            }
          ]
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") FROM \"homeassistant\".\"autogen\".\"ppm\" WHERE (\"entity_id\" =~ /.*hvac_average_co2$/) AND $timeFilter GROUP BY time($__interval), \"entity_id\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_entity_id"
          },
          {
            "refId": "B",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT 600 AS \"value\" FROM \"homeassistant\".\"autogen\".\"ppm\" WHERE $timeFilter GROUP BY time($__interval) LIMIT 1",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "600 ppm",
            "hide": true
          },
          {
            "refId": "C",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT 800 AS \"value\" FROM \"homeassistant\".\"autogen\".\"ppm\" WHERE $timeFilter GROUP BY time($__interval) LIMIT 1",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "800 ppm",
            "hide": true
          }
        ]
      },
      {
        "id": 4,
        "title": "Mode Changes",
        "type": "state-timeline",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {
                "HEAT": {"text": "Heat", "color": "dark-orange"},
                "HEATING": {"text": "Heating", "color": "dark-orange"},
                "COOL": {"text": "Cool", "color": "dark-blue"},
                "COOLING": {"text": "Cooling", "color": "dark-blue"},
                "AUTO": {"text": "Auto", "color": "dark-green"},
                "AUTOHEAT": {"text": "Auto (Heat)", "color": "orange"},
                "AUTOCOOL": {"text": "Auto (Cool)", "color": "blue"},
                "DRY": {"text": "Dry", "color": "dark-yellow"},
                "FAN": {"text": "Fan", "color": "dark-purple"}
              }},
              {"type": "special", "options": {"match": "empty", "result": {"text": "Unknown", "color": "text"}}}
            ],
            "custom": {"fillOpacity": 80}
          }
        },
        "options": {
          "showValue": "auto",
          "mergeValues": true,
          "legend": {"displayMode": "list", "placement": "bottom"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"mode\") FROM \"ae200_state\" WHERE \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\" fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name"
          }
        ]
      },
      {
        "id": 5,
        "title": "Humidity",
        "description": "Per-zone humidity with humidifier/dehumidifier state overlay",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 28},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "spanNulls": true
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": ".*humidifier.*|.*dehumidifier.*"},
              "properties": [
                {"id": "custom.drawStyle", "value": "bars"},
                {"id": "custom.fillOpacity", "value": 30},
                {"id": "custom.lineWidth", "value": 0},
                {"id": "unit", "value": "bool_on_off"},
                {"id": "custom.axisPlacement", "value": "hidden"},
                {"id": "max", "value": 1}
              ]
            }
          ]
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last", "min", "max"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") FROM \"homeassistant\".\"autogen\".\"%\" WHERE (\"entity_id\" =~ /.*hvac_average_humidity$/) AND $timeFilter GROUP BY time($__interval), \"entity_id\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_entity_id"
          },
          {
            "refId": "B",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT last(\"state\") FROM \"homeassistant\".\"autogen\".\"state\" WHERE (\"entity_id\" = 'humidifier' OR \"entity_id\" = 'dehumidifier_basement' OR \"entity_id\" = 'dehumidifier_main') AND $timeFilter GROUP BY time($__interval), \"entity_id\" fill(previous)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_entity_id"
          }
        ]
      },
      {
        "id": 6,
        "title": "Setpoints",
        "description": "Setpoint temperatures over time per zone",
        "type": "timeseries",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 38},
        "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
        "fieldConfig": {
          "defaults": {
            "unit": "fahrenheit",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 0,
              "lineStyle": {"fill": "dash", "dash": [10, 10]},
              "spanNulls": true
            }
          }
        },
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {
            "refId": "A",
            "datasource": {"uid": "dfg9alzo4kykgb", "type": "influxdb"},
            "query": "SELECT mean(\"value\") * 9 / 5 + 32 FROM \"ae200_temperature\" WHERE (\"type\" = 'setpoint' OR \"type\" = 'setpoint_cool' OR \"type\" = 'setpoint_heat') AND \"group_name\" =~ /^$unit$/ AND \"group_name\" != 'HOT WATER SYSTEM' AND $timeFilter GROUP BY time($__interval), \"group_name\", \"type\" fill(linear)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "alias": "$tag_group_name ($tag_type)"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
