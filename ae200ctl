def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="ae200ctl",
        description="Query and configure Mitsubishi AE-200 controllers.",
    )
    p.add_argument("--host", required=True, help="IP address of the AE-200 controller")
    p.add_argument(
        "--timeout", type=float, default=10.0,
        help="WebSocket response timeout in seconds (default: 10)",
    )
    p.add_argument(
        "--raw-xml", action="store_true",
        help="Include raw XML response in output",
    )

    sub = p.add_subparsers(dest="subcommand", required=True)

    sub.add_parser("list", help="List all device groups")

    sp_status = sub.add_parser("status", help="Get device runtime status")
    sp_status.add_argument("--group", "-g", help="Device group ID (omit for all)")

    sp_set = sub.add_parser("set", help="Set device attributes")
    sp_set.add_argument("group", help="Device group ID")
    sp_set.add_argument("settings", nargs="+", help="key=value pairs (e.g. Drive=ON Mode=COOL)")

    sub.add_parser("system", help="Get system configuration")
    sub.add_parser("mnet-status", help="Get M-NET bus status")
    sub.add_parser("groups", help="Get control group configuration")
    sub.add_parser("areas", help="Get area configuration")
    sub.add_parser("interlocks", help="Get interlock configuration")
    sub.add_parser("alarms", help="Get alarm configuration")
    sub.add_parser("functions", help="Get licensed functions")
    sub.add_parser("schedule", help="Get schedule/season configuration")
    sub.add_parser("energy", help="Get energy management configuration")

    sp_raw = sub.add_parser("raw", help="Send raw XML request")
    sp_raw.add_argument("command", choices=["get", "set"], help="Request type")
    sp_raw.add_argument("xml_body", help="XML body to place inside <DatabaseManager>")

    return p


COMMANDS = {
    "list": cmd_list,
    "status": cmd_status,
    "set": cmd_set,
    "system": cmd_system,
    "mnet-status": cmd_mnet_status,
    "groups": cmd_groups,
    "areas": cmd_areas,
    "interlocks": cmd_interlocks,
    "alarms": cmd_alarms,
    "functions": cmd_functions,
    "schedule": cmd_schedule,
    "energy": cmd_energy,
    "raw": cmd_raw,
}


async def main():
    parser = build_parser()
    args = parser.parse_args()

    handler = COMMANDS.get(args.subcommand)
    if not handler:
        parser.print_help()
        sys.exit(1)

    try:
        result = await handler(args.host, args)
        print(json.dumps(result, indent=2, ensure_ascii=False))
    except (ConnectionRefusedError, OSError) as e:
        print(json.dumps({"error": "connection_refused", "detail": str(e)}), file=sys.stderr)
        sys.exit(1)
    except asyncio.TimeoutError:
        print(json.dumps({"error": "timeout", "detail": f"No response within {args.timeout}s"}), file=sys.stderr)
        sys.exit(1)
    except ET.ParseError as e:
        print(json.dumps({"error": "invalid_xml", "detail": str(e)}), file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(json.dumps({"error": str(type(e).__name__), "detail": str(e)}), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    asyncio.run(main())
