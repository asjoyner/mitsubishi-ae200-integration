#!/usr/bin/env python3
"""ae200ctl - CLI tool for querying and configuring Mitsubishi AE-200 controllers.

Usage:
    ae200ctl --host <ip> list
    ae200ctl --host <ip> status [--group N]
    ae200ctl --host <ip> set <group> key=value [key=value ...]
    ae200ctl --host <ip> system
    ae200ctl --host <ip> mnet-status
    ae200ctl --host <ip> groups
    ae200ctl --host <ip> areas
    ae200ctl --host <ip> interlocks
    ae200ctl --host <ip> alarms
    ae200ctl --host <ip> functions
    ae200ctl --host <ip> schedule
    ae200ctl --host <ip> energy
    ae200ctl --host <ip> raw <get|set> <xml_body>

All output is JSON for easy parsing by humans and scripts.
"""

import argparse
import asyncio
import json
import sys
import xml.etree.ElementTree as ET

from ae200lib.transport import ws_request
from ae200lib.protocol import (
    get_request,
    set_request,
    wrap,
    mnet_query,
    system_query,
    parse_response,
)


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

async def cmd_list(host: str, _args) -> dict:
    """List all device groups on the controller."""
    payload = get_request("<ControlGroup><MnetList /></ControlGroup>")
    raw = await ws_request(host, payload)
    root = ET.fromstring(raw)
    groups = []
    for r in root.findall(".//MnetRecord"):
        groups.append({"id": r.get("Group"), "name": r.get("GroupNameWeb")})
    return {"groups": groups}


async def cmd_status(host: str, args) -> dict:
    """Get runtime status for one or all devices."""
    if args.group:
        ids = [args.group]
    else:
        listing = await cmd_list(host, args)
        ids = [g["id"] for g in listing["groups"]]

    raw = await ws_request(host, mnet_query(ids))
    root = ET.fromstring(raw)
    devices = []
    for mnet in root.findall(".//Mnet"):
        devices.append(dict(mnet.attrib))
    if len(devices) == 1:
        return devices[0]
    return {"devices": devices}


async def cmd_set(host: str, args) -> dict:
    """Set attributes on a device group."""
    attrs = {}
    for kv in args.settings:
        if "=" not in kv:
            return {"error": f"Invalid setting '{kv}', expected key=value"}
        k, v = kv.split("=", 1)
        attrs[k] = v

    attr_str = " ".join(f'{k}="{v}"' for k, v in attrs.items())
    payload = set_request(f'<Mnet Group="{args.group}" {attr_str} />')
    raw = await ws_request(host, payload)
    result = parse_response(raw)
    result["requested"] = {"group": args.group, **attrs}
    return result


async def cmd_system(host: str, _args) -> dict:
    """Get system-level configuration."""
    raw = await ws_request(host, system_query())
    return parse_response(raw)


async def cmd_mnet_status(host: str, _args) -> dict:
    """Get M-NET bus status and per-unit health summary."""
    bus_raw = await ws_request(host, get_request('<SystemData MnetStatus="*" />'))
    bus = parse_response(bus_raw)
    mnet_status = bus.get("SystemData", {}).get("MnetStatus", "UNKNOWN")

    listing = await cmd_list(host, _args)
    ids = [g["id"] for g in listing["groups"]]
    health_attrs = ("ErrorSign", "ModeStatus", "Drive", "Mode", "InletTemp", "SetTemp", "Model", "FilterSign")
    attrs_str = " ".join(f'{a}="*"' for a in health_attrs)
    mnets = "".join(f'<Mnet Group="{gid}" {attrs_str} />' for gid in ids)
    units_raw = await ws_request(host, get_request(mnets))
    root = ET.fromstring(units_raw)
    units = []
    for mnet in root.findall(".//Mnet"):
        units.append(dict(mnet.attrib))

    return {"mnet_bus": mnet_status, "units": units}


async def cmd_groups(host: str, _args) -> dict:
    """Get control group configuration."""
    payload = get_request("<ControlGroup><MnetGroupList /></ControlGroup>")
    raw = await ws_request(host, payload)
    return parse_response(raw)


async def cmd_areas(host: str, _args) -> dict:
    """Get area group and area list configuration."""
    payload = get_request("<ControlGroup><AreaGroupList /><AreaList /></ControlGroup>")
    raw = await ws_request(host, payload)
    return parse_response(raw)


async def cmd_interlocks(host: str, _args) -> dict:
    """Get interlock configuration."""
    payload = get_request("<ControlGroup><InterlockList /></ControlGroup>")
    raw = await ws_request(host, payload)
    return parse_response(raw)


async def cmd_alarms(host: str, _args) -> dict:
    """Get alarm configuration."""
    payload = get_request(
        "<Alarm><AlarmCodeList /><AlarmRouteList /></Alarm>"
    )
    raw = await ws_request(host, payload)
    return parse_response(raw)


async def cmd_functions(host: str, _args) -> dict:
    """Get licensed function list with resolved names."""
    payload = get_request(
        "<FunctionControl><FunctionList /></FunctionControl>"
    )
    raw = await ws_request(host, payload)
    result = parse_response(raw)
    records = (
        result.get("FunctionControl", {})
        .get("FunctionList", {})
        .get("FunctionRecord", [])
    )
    if isinstance(records, dict):
        records = [records]
    functions = []
    for rec in records:
        idx = rec.get("Index", "")
        functions.append({
            "index": idx,
            "name": FUNCTION_NAMES.get(idx, f"Unknown_{idx}"),
            "status": rec.get("Status", ""),
            "time_limit": rec.get("TimeLimit", ""),
        })
    return {"functions": functions}


async def cmd_schedule(host: str, _args) -> dict:
    """Get schedule control and season type configuration."""
    payload = get_request('<ScheduleControl SeasonType="*" />')
    raw = await ws_request(host, payload)
    return parse_response(raw)


async def cmd_energy(host: str, _args) -> dict:
    """Get energy management configuration."""
    payload = get_request(
        "<EnergyManagement><UnitSourceList /></EnergyManagement>"
    )
    raw = await ws_request(host, payload)
    return parse_response(raw)


async def cmd_raw(host: str, args) -> dict:
    """Send a raw XML body inside the Packet/DatabaseManager envelope."""
    command = "getRequest" if args.command == "get" else "setRequest"
    payload = wrap(command, args.xml_body)
    raw = await ws_request(host, payload, timeout=args.timeout)
    return parse_response(raw)


